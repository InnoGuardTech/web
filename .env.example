# ============================================
#  حراج اليمن - متغيرات البيئة (Example File)
#  انسخ هذا الملف إلى .env وعدّل القيم
# ============================================

# --- بيئة التشغيل ---
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost/haraj-yemen

# --- قاعدة البيانات MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=haraj_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# --- مفتاح التشفير / الجلسات ---
APP_KEY=change_this_to_a_random_64_char_string
SESSION_LIFETIME=7200
SESSION_SECURE_COOKIE=false

# --- إعدادات الرفع ---
MAX_UPLOAD_SIZE=5242880
MAX_IMAGES_PER_AD=8
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif

# --- البريد الإلكتروني (SMTP) ---
MAIL_DRIVER=log
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@haraj-yemen.com
MAIL_FROM_NAME="حراج اليمن"

# --- SMS / OTP ---
SMS_DRIVER=log
SMS_API_KEY=
SMS_SENDER_ID=HarajYemen

# --- الإدارة ---
ADMIN_WHATSAPP=777000000
ADMIN_EMAIL=admin@haraj-yemen.com

# --- معدّل الطلبات (Rate Limiting) ---
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_WINDOW=300

# --- العمولة ---
COMMISSION_RATE=0.01
